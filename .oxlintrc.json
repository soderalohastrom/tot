{
	"$schema": "./node_modules/oxlint/configuration_schema.json",
	"plugins": ["typescript"],
	"categories": {
		"correctness": "error",
		"suspicious": "warn",
		"perf": "warn"
	},
	"rules": {
		"no-unused-vars": [
			"error",
			{
				"caughtErrorsIgnorePattern": "^_",
				"varsIgnorePattern": "^_",
				"argsIgnorePattern": "^_"
			}
		],
		"@typescript-eslint/no-non-null-assertion": "off",
		"@typescript-eslint/no-explicit-any": "off",
		"no-shadow": "off"
	},
	"ignorePatterns": ["**/dist/**", "**/node_modules/**"]
}
